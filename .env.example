# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication (leave blank for local demo mode)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_TELEMETRY_DISABLED=true

# Codex uses the login already stored by the local Codex CLI.
# Optional: override the SDK's bundled Codex runner.
CODEX_BINARY_PATH=
SNOBALL_THREAD_SECRET=
SNOBALL_MARIGOLD_WORKSPACE=

# Direct Stripe Billing (optional until monetization is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEMO_CUSTOMER_ID=
STRIPE_BASE_PRICE_ID=
STRIPE_METERED_PRICE_ID=
STRIPE_CODEX_METER_EVENT_NAME=snoball_codex_tokens
SNOBALL_BILLING_MODE=disabled
